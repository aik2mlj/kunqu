# Crop config for 东方大剧院_岳美缇《拾画叫画》 (CIBN source, 1920x1080).
# Lyrics sit bottom-center (~y 855-940). Box avoids the right-side vertical
# title (昆剧《牡丹亭·拾画叫画》) and the bottom-right 东方大剧院 logo.
#
# First estimate — run `./run_play.sh probe shihuajiaohua "<video>"`, open
# output/shihuajiaohua/probe_crop.jpg, and tweak these numbers until the red box
# hugs the lyric line. Command-line CROP_* still overrides this file.
CROP=on
CROP_X=560
CROP_Y=833
CROP_WIDTH=800
CROP_HEIGHT=95
