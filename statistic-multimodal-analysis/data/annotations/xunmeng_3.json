    "subtitleLines": [
      {
        "id": "line-1",
        "text": "春江花月夜",
        "startTime": 12.4,
        "endTime": 47.6
      },
      {
        "id": "line-2",
        "text": "良辰美景天",
        "startTime": 50.79999999999999,
        "endTime": 77.2
      },
      {
        "id": "line-3",
        "text": "水袖轻翻意未歇",
        "startTime": 82.00000000000001,
        "endTime": 120.39999999999999
      },
      {
        "id": "line-54a508ae-8439-4546-890d-77a9cad80c44",
        "text": "都不见了",
        "startTime": 750.6358608362997,
        "endTime": 755.8437117048843
      },
      {
        "id": "line-19206850-4370-4adb-8681-8ea20750b29d",
        "text": "那牡丹亭芍药栏",
        "startTime": 756.4342459711274,
        "endTime": 773.337238304267
      },
      {
        "id": "line-fb56ebfc-52f0-4489-bbf7-2626b1faf6a4",
        "text": "怎生这般凄凉冷落",
        "startTime": 774.332315250865,
        "endTime": 785.079732779321
      },
      {
        "id": "line-38668121-0cc2-4606-be2c-e680a15fcda1",
        "text": "杳无人迹",
        "startTime": 785.5619789341765,
        "endTime": 791.5678806232378
      },
      {
        "id": "line-5322aea2-f787-4b2f-b495-35a5b8d2d22a",
        "text": "好伤感人也",
        "startTime": 792.5845011367824,
        "endTime": 810.2997807796479
      },
      {
        "id": "line-0201c253-6a05-45d7-978e-df2aaf16662a",
        "text": "似这等荒凉地面",
        "startTime": 814.7768439743793,
        "endTime": 853.9530917863136
      },
      {
        "id": "line-af7c102d-429c-4f53-8fd2-b79b66e6de76",
        "text": "没多半亭台靠",
        "startTime": 854.0873950383422,
        "endTime": 868.9463110795963
      },
      {
        "id": "line-ec3f816f-d7da-4d6d-88c9-05d3f8e294d1",
        "text": "边",
        "startTime": 868.9463110795963,
        "endTime": 872.3586519677627
      },
      {
        "id": "line-3a69bc82-2762-4b7f-b362-30fd58c1ec68",
        "text": "敢是咱眯睎色眼寻难见",
        "startTime": 872.6705495710254,
        "endTime": 894.3428877525686
      },
      {
        "id": "line-bebd1130-940f-41cb-9707-d69e9006cf10",
        "text": "放着白日青天",
        "startTime": 894.5473726358991,
        "endTime": 910.0458228273998
      },
      {
        "id": "line-483c867d-fe76-4527-bac5-297a3ce76840",
        "text": "猛教人抓不到魂梦前",
        "startTime": 910.0458228273998,
        "endTime": 931.0713949080341
      },
      {
        "id": "line-b158c8b0-8cf8-4bbf-9e37-c3f5ce24ee9e",
        "text": "霎时间有如活现",
        "startTime": 931.0713949080341,
        "endTime": 950.0296189142019
      },
      {
        "id": "line-16457c0c-fbbc-484a-a3d5-3d56aa029301",
        "text": "打方旋再得俄延",
        "startTime": 950.5592685855162,
        "endTime": 971.3198717669353
      },
      {
        "id": "line-2463fc4a-c616-4f56-98b7-d159afc494df",
        "text": "是这答儿压黄金",
        "startTime": 971.8491252634648,
        "endTime": 992.2309173206544
      }
    ],
