    "subtitleLines": [
      {
        "id": "line-a38217a5-69f3-4cfc-af43-ded320438b85",
        "text": "一丝丝垂杨线",
        "startTime": 254.7090827112631,
        "endTime": 275.32084556888645
      },
      {
        "id": "line-5a99f71e-bd38-44a5-90b1-cd759add3b2b",
        "text": "一丢丢榆英钱",
        "startTime": 275.73453267835566,
        "endTime": 288.5539171944214
      },
      {
        "id": "line-eda44149-b6d6-4b14-a71a-a77098dd0ac7",
        "text": "啊线儿春甚金钱啊吊转",
        "startTime": 289.2556606244033,
        "endTime": 330.04289179085254
      },
      {
        "id": "line-16141ae6-a19f-4548-b532-5d74fc93f095",
        "text": "昨日梦里",
        "startTime": 345.3114181630736,
        "endTime": 348.9070200879695
      },
      {
        "id": "line-92c9250a-62b1-4897-9e4b-bf336f4f7d8d",
        "text": "那书生将柳枝来赠我",
        "startTime": 350.1390988381606,
        "endTime": 359.99274792038995
      },
      {
        "id": "line-3c4638ab-aca8-407d-87fa-bca332ab3033",
        "text": "要我题咏",
        "startTime": 360.93748917561555,
        "endTime": 366.96183233091216
      },
      {
        "id": "line-1d7f019d-0e00-499a-8010-605947ceba54",
        "text": "强奴欢会之时",
        "startTime": 367.96145893780204,
        "endTime": 376.4188547705071
      },
      {
        "id": "line-eed13928-f2f9-4d91-8830-9e46d763379e",
        "text": "好不话长也",
        "startTime": 377.4828171405788,
        "endTime": 396.12622781451563
      },
      {
        "id": "line-7bd574f7-5a8a-41c2-b98e-a09ab4f723fc",
        "text": "是谁家少俊来近远",
        "startTime": 401.4626404451957,
        "endTime": 457.8087099042159
      },
      {
        "id": "line-3c54f91b-2eeb-430b-87a5-c28c0cc4a0c9",
        "text": "敢迤逗这香闺去沁园",
        "startTime": 458.51116534554484,
        "endTime": 493.61603603873147
      },
      {
        "id": "line-820aad99-c3a8-4866-9fbf-61c0a5d1d3d4",
        "text": "话到其间腼腆",
        "startTime": 494.1127737564086,
        "endTime": 528.0250075722676
      }
    ],
