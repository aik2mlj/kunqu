    "subtitleLines": [
      {
        "id": "line-c2fa5cc5-46f1-4aca-b4ab-d2edb33f148c",
        "text": "钏匾",
        "startTime": 991.9243560900804,
        "endTime": 1006.158697012627
      },
      {
        "id": "line-60ab4d2f-a1f6-4eee-9b34-aa708cd6463d",
        "text": "秀才秀才",
        "startTime": 1010.3545989994319,
        "endTime": 1018.8548617956142
      },
      {
        "id": "line-2db89db6-9559-4259-8ba3-8542c682b760",
        "text": "呀无人之处",
        "startTime": 1042.0183077376942,
        "endTime": 1048.772378615787
      },
      {
        "id": "line-9d460ef8-4494-4d10-af78-16c63b5c31ae",
        "text": "忽见大梅树一株",
        "startTime": 1049.7751885298467,
        "endTime": 1063.6618471046927
      },
      {
        "id": "line-fee23bd5-7280-4a64-aece-5be7de2c8127",
        "text": "看梅子累累可爱人也",
        "startTime": 1080.7415186,
        "endTime": 1098.0496925202049
      },
      {
        "id": "line-20760ffc-c134-40ff-b080-0ccf13ab6d34",
        "text": "我丽娘死后得葬于此",
        "startTime": 1101.5307050836768,
        "endTime": 1121.0408641442068
      },
      {
        "id": "line-1abd849e-e906-4fad-9924-f52ba8eaad30",
        "text": "幸也",
        "startTime": 1121.954935016922,
        "endTime": 1132.3194247193028
      },
      {
        "id": "line-badbfba9-5645-438b-b20d-c777ca790ce9",
        "text": "偶然间心似缱",
        "startTime": 1136.5878088565046,
        "endTime": 1162.4992868091229
      },
      {
        "id": "line-d3f090f9-fba3-41f6-b313-acf905431afc",
        "text": "在梅树边",
        "startTime": 1162.4992868091229,
        "endTime": 1174.3422414992565
      },
      {
        "id": "line-3b532a35-9a5f-4172-846f-553d36b2fdaf",
        "text": "似这等花花草草由人恋",
        "startTime": 1174.5180864529498,
        "endTime": 1201.6821191170663
      },
      {
        "id": "line-1a5a9578-29ce-4dcc-ad21-3f91fee29ce4",
        "text": "生生死死遂人愿",
        "startTime": 1202.0168188191049,
        "endTime": 1220.103943433661
      },
      {
        "id": "line-88b322ba-d48e-404f-93c0-590595ff68fb",
        "text": "便酸酸楚楚无人怨",
        "startTime": 1220.7624681,
        "endTime": 1237.1761000503682
      }
    ],
