        "endTime": 1805.4
      },
      {
        "id": "line-142",
        "text": "盈盈欲下",
        "startTime": 1805.4,
        "endTime": 1809.96
      },
      {
        "id": "line-143",
        "text": "全不见些影儿",
        "startTime": 1809.96,
        "endTime": 1818.12
      },
      {
        "id": "line-144",
        "text": "小娘子小生孤单在此",
        "startTime": 1818.12,
        "endTime": 1823.04
      },
      {
        "id": "line-145",
        "text": "少不得将小娘子的画像",
        "startTime": 1823.04,
        "endTime": 1826.28
      },
      {
        "id": "line-146",
        "text": "做个伴侣儿",
        "startTime": 1826.28,
        "endTime": 1830.12
      },
      {
        "id": "line-147",
        "text": "早晚么",
        "startTime": 1830.12,
        "endTime": 1832.52
      },
      {
        "id": "line-148",
        "text": "玩之叫之拜之",
        "startTime": 1832.52,
        "endTime": 1839.84
      },
      {
        "id": "line-149",
        "text": "赞赞赞之",
        "startTime": 1848.36,
