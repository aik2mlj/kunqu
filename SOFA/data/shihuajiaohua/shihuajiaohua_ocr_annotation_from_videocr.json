      },
      {
        "id": "line-150",
        "text": "赞赞赞之",
        "startTime": 1851.12,
        "endTime": 1852.44
      },
      {
        "id": "line-151",
        "text": "【尾声】俺拾得个人儿先庆贺",
        "startTime": 1858.68,
        "endTime": 1878.24
      },
      {
        "id": "line-152",
        "text": "敢柳和梅有些瓜葛",
        "startTime": 1878.24,
        "endTime": 1898.52
      },
      {
        "id": "line-153",
        "text": "美人哪",
        "startTime": 1898.52,
        "endTime": 1910.88
      },
      {
        "id": "line-154",
        "text": "只被你有影无形盼煞我",
        "startTime": 1910.88,
        "endTime": 1953.84
      },
      {
        "id": "line-155",
        "text": "哦哟",
        "startTime": 1958.04,
        "endTime": 1960.08
      },
      {
        "id": "line-156",
        "text": "啊小娘子这里有风",
        "startTime": 1960.32,
        "endTime": 1963.2
      },
      {
        "id": "line-157",
        "text": "请到里边去坐",
