    "subtitleLines": [
      {
        "id": "line-1",
        "text": "春江花月夜",
        "startTime": 12.4,
        "endTime": 47.6
      },
      {
        "id": "line-2",
        "text": "良辰美景天",
        "startTime": 50.79999999999999,
        "endTime": 77.2
      },
      {
        "id": "line-3",
        "text": "水袖轻翻意未歇",
        "startTime": 82.00000000000001,
        "endTime": 120.39999999999999
      },
      {
        "id": "line-3b532a35-9a5f-4172-846f-553d36b2fdaf",
        "text": "待打并香魂一片阴雨梅天啊呀人儿吓",
        "startTime": 1237.292063210227,
        "endTime": 1276.716874145591
      },
      {
        "id": "line-30d77a93-d27e-4b22-a8e5-69cf18de0390",
        "text": "守得个梅根相见",
        "startTime": 1281.027737885109,
        "endTime": 1311.5767953849945
      },
      {
        "id": "line-901e48ae-9fdc-49a5-bcb1-93d51946f059",
        "text": "佳人拾翠春庭院侍女添香午院清不知小姐哪里去了",
        "startTime": 1317.5596354166667,
        "endTime": 1328.9542875107022
      },
      {
        "id": "line-7c758dfb-a475-42b0-8e50-4030b90db1ed",
        "text": "呀看小姐走乏了在梅树边打睡呢小姐",
        "startTime": 1331.829430650685,
        "endTime": 1339.4174229452053
      },
      {
        "id": "line-9f47db0b-27e5-4634-ae55-bfbea9b54e23",
        "text": "小姐",
        "startTime": 1340.9037243150685,
        "endTime": 1345.7855094178083
      },
      {
        "id": "line-37b6f689-b025-4660-847c-5e340ee0315a",
        "text": "春香小姐",
        "startTime": 1355.8906892123289,
        "endTime": 1359.4331549657534
      },
      {
        "id": "line-0b9b6825-f15e-4db0-88cd-71fbdb6f6dc3",
        "text": "我",
        "startTime": 1361.0731485445206,
        "endTime": 1361.7086258561644
      },
      {
        "id": "line-ff3faae1-2ceb-4310-8d00-9e213857998c",
        "text": "丽娘哭？",
        "startTime": 1363.3514982876711,
        "endTime": 1375.4359053938358
      },
      {
        "id": "line-c7f19be2-b457-4b9f-ad71-25234a335ccb",
        "text": "少不得楼上花枝也则是照独眠",
        "startTime": 1378.8717819940475,
        "endTime": 1440.5543526785716
      }
    ],
