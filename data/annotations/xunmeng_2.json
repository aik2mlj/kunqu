    "subtitleLines": [
      {
        "id": "line-2631dc39-025d-4f8c-9a23-bdd990cfdfc2",
        "text": "话到其间腼腆",
        "startTime": 493.8875,
        "endTime": 528.1892578124999
      },
      {
        "id": "line-f4ac4aec-11af-45d6-9729-97b2b542b660",
        "text": "他捏这眼奈烦也天",
        "startTime": 528.4702287946428,
        "endTime": 551.2207589285714
      },
      {
        "id": "line-e0eb72e9-1bbe-42bd-9597-e78f649bd5a2",
        "text": "咱噷这口待酬言",
        "startTime": 551.3738839285714,
        "endTime": 580.1545354833745
      },
      {
        "id": "line-9a723635-0b8a-42a4-b777-56a081a118f8",
        "text": "咱不是前生爱眷",
        "startTime": 580.1545354833745,
        "endTime": 600.23984375
      },
      {
        "id": "line-690412e8-6199-4e13-bdc7-da4afb564572",
        "text": "又素乏平生半面",
        "startTime": 600.23984375,
        "endTime": 629.6482142857143
      },
      {
        "id": "line-d82f5055-604c-4ae7-849b-9c6a6270167d",
        "text": "则道来生出现",
        "startTime": 629.7284040178571,
        "endTime": 638.4190848214286
      },
      {
        "id": "line-2b738880-deb4-4abb-91bf-b4a19b3ccbf2",
        "text": "乍便今生梦见",
        "startTime": 638.4190848214286,
        "endTime": 664.5235491071428
      },
      {
        "id": "line-f6d917ba-037c-451c-a1d1-403bd76c4e28",
        "text": "生就个书生",
        "startTime": 664.6021763392857,
        "endTime": 683.2121651785714
      },
      {
        "id": "line-bc8646f6-1002-4379-87f1-c3371b0030b8",
        "text": "恰恰生生抱咱去眠",
        "startTime": 683.2121651785714,
        "endTime": 731.5867745535713
      },
      {
        "id": "line-b1e8cd8a-ce91-4cee-a3bd-2c32707d50a0",
        "text": "寻来寻去都不见了",
        "startTime": 739.8568080357143,
        "endTime": 756.2603236607143
      }
    ],
